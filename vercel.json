{
  "buildCommand": "npm install && npm --prefix server install && npm --prefix server run db:generate && npm run build",
  "outputDirectory": "dist",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/handler.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/handler.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
